{% extends "page/checkout/order.html.twig" %}

{% block checkout_order_address %}
    {{ parent() }}
    {% if attribute(oViewConf, 'isMolliePayPalExpressCheckout') is defined and oViewConf.isMolliePayPalExpressCheckout() is same as(true) %}
        {% set mollie_hide_changebuttons %}
            document.addEventListener("DOMContentLoaded", function () {
                document.querySelectorAll('#orderAddress FORM BUTTON.btn').forEach(function(button) {
                    button.remove();
                });
            });
        {% endset %}
        {{ script({ add: mollie_hide_changebuttons.__toString(), priority: 10, dynamic: __oxid_include_dynamic }) }}
    {% endif %}
{% endblock %}